Options -Indexes
RewriteEngine On
RewriteBase /

# Clean URL: /page-name → /page-name.html
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^([^.]+)$ $1.html [L,QSA]

# transfer.gobiglinker.com 라우팅 맵
# / → index.html
# /total-admission-coaching → total-admission-coaching.html
# /school-record-coaching   → school-record-coaching.html
# /interview-coaching       → interview-coaching.html
# /essay-coaching           → essay-coaching.html
